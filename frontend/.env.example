# Backend URL for the Vite dev server proxy (development only)
# Points to where your FastAPI backend is running locally
VITE_BACKEND_URL=http://localhost:8002

# Full API base URL for production builds (no Vite proxy in production)
# In dev, leave this unset — the proxy handles it via VITE_BACKEND_URL
# In production: https://your-backend-domain.com/api
VITE_API_BASE_URL=
